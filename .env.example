# ─── Server ───────────────────────────────────────────────────
SERVER_PORT=8080

# ─── PostgreSQL ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=cardeal
DB_PASSWORD=CHANGE_ME_use_a_strong_password
DB_NAME=cardeal
DB_SSLMODE=disable
DB_MAX_CONNS=25

# ─── Redis ────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL_DAYS=7

# ─── AI Provider (OpenAI-compatible) ─────────────────────────
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o
AI_BASE_URL=https://api.openai.com/v1
AI_MAX_TOKENS=4096

# ─── External APIs ───────────────────────────────────────────
# Biluppgifter.se — Primary vehicle data source (get key at biluppgifter.se/api)
BILUPPGIFTER_API_KEY=
BILUPPGIFTER_BASE_URL=https://api.biluppgifter.se/api/v1

# car.info — Additional data source (future)
CARINFO_API_KEY=
CARINFO_BASE_URL=https://api.car.info/v1

# ─── Logging ─────────────────────────────────────────────────
RUST_LOG=cardeal=info,tower_http=info
