# ─── Server ───────────────────────────────────────────────────
SERVER_PORT=8080

# ─── PostgreSQL ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=cardeal
DB_PASSWORD=cardeal_secret
DB_NAME=cardeal
DB_SSLMODE=disable
DB_MAX_CONNS=25

# ─── Redis ────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL_DAYS=7

# ─── AI Provider (OpenAI-compatible) ─────────────────────────
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o
AI_BASE_URL=https://api.openai.com/v1
AI_MAX_TOKENS=4096

# ─── External APIs (future integration) ──────────────────────
CARINFO_API_KEY=
CARINFO_BASE_URL=https://api.car.info/v1

# ─── Logging ─────────────────────────────────────────────────
RUST_LOG=cardeal=info,tower_http=info
